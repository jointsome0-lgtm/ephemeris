# Ephemeris — systemd *user* service template.
#
# This is a committed, portable template (host 127.0.0.1, %h paths). Copy it to
# your user unit directory and adjust before enabling — do NOT symlink it, so
# your local host choice never lands back in Git:
#
#   mkdir -p ~/.config/systemd/user
#   cp deploy/ephemeris.service.example ~/.config/systemd/user/ephemeris.service
#   # For phone/LAN access, change --host to 0.0.0.0 in the copy (see note below).
#   systemctl --user daemon-reload
#   systemctl --user enable --now ephemeris
#   loginctl enable-linger "$USER"   # keep running after logout / across reboots
#
# %h expands to your home dir; this assumes the repo lives at ~/projects/ephemeris.

[Unit]
Description=Ephemeris — personal activity ledger
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/projects/ephemeris
# Optional: the ledger clock that defines "today". Defaults to the host zone.
Environment=APP_TIMEZONE=Europe/Moscow
# The ledger must live outside the public checkout; adjust this path in your copy.
Environment=ACTIVITY_DATA_DIR=%h/.local/share/ephemeris
# The embedded terminal (a real shell over a websocket) is OFF by default.
# Opt in ONLY on a single-user desktop with --host 127.0.0.1 and never with
# --proxy-headers (see docs/security-model.md), by uncommenting:
#Environment=EPHEMERIS_ENABLE_TERMINAL=1
# Concrete venv interpreter built by `uv sync` — no PATH/shim dependency.
# Default 127.0.0.1 = desktop-only (safe). The app has NO AUTH.
# For phone/LAN access change to --host 0.0.0.0 — ONLY on a trusted network.
ExecStart=%h/projects/ephemeris/.venv/bin/python -m uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=3
# New files (DB, exports, lesson briefs) stay private to the service user.
UMask=0077
# Bound the service (and anything spawned inside it, e.g. an opted-in terminal
# shell): the whole cgroup is capped, runaway processes get killed, not the host.
MemoryMax=2G
TasksMax=256

[Install]
WantedBy=default.target
